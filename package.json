{
  "name": "currency-converter",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test:unit": "jest --config=jest.config.allure.js",
    "test:api": "cucumber-js --config cucumber.js --format json:allure-results/cucumber.json",
    "test:ui": "npx playwright test --reporter=line,allure-playwright",
    "test:ui:headed": "npx playwright test --headed",
    "test:ui:report": "npx playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui && npm run allure:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@playwright/test": "^1.40.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.0",
    "allure-playwright": "^3.7.0",
    "jest": "^30.0.5",
    "jest-allure2": "^1.2.3",
    "playwright": "^1.40.0",
    "supertest": "^7.1.1",
    "wait-on": "^8.0.3"
  }
}
